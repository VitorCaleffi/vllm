# Self-contained Dockerfile for AMD Strix Halo (gfx1150/gfx1151) APUs
#
# Builds PyTorch, Triton, and vLLM from source against ROCm 7.2 to guarantee
# ABI consistency. Targets only gfx1150;gfx1151 architectures.
#
# Key differences from the upstream Dockerfile.rocm_base + Dockerfile.rocm:
#   - Single self-contained file (vs upstream's two-file base+app split)
#   - Targets only gfx1150;gfx1151 (not MI300/MI325/RDNA3/RDNA4)
#   - Skips AITER, MORI, CK Flash Attention (unsupported on gfx11xx)
#   - All Strix Halo-specific env vars and workarounds pre-configured
#
# Build:
#   docker build -f docker/Dockerfile.rocm.strix-halo -t vllm-strix-halo .
#
# Run:
#   docker run --device=/dev/kfd --device=/dev/dri \
#     --group-add video --group-add render \
#     --security-opt seccomp=unconfined \
#     vllm-strix-halo \
#     vllm serve <model> --dtype float16 --no-mmap
#
# Host requirements:
#   - Linux kernel >= 6.18.4 (older kernels have KFD bugs for Strix Halo)
#   - Avoid linux-firmware-20251125 (breaks ROCm)
#   - Kernel boot params: iommu=pt amdgpu.gttsize=126976 ttm.pages_limit=32505856
#   - BIOS GPU memory set to minimum (512MB); use GTT/TTM for unified memory
#   - Docker flags: --device=/dev/kfd --device=/dev/dri --group-add video
#                   --group-add render --security-opt seccomp=unconfined

ARG BASE_IMAGE=rocm/dev-ubuntu-24.04:7.2-complete

# PyTorch / Triton / Flash Attention source branches
# These should be ROCm forks that support ROCm 7.2
ARG PYTORCH_BRANCH="89075173"
ARG PYTORCH_REPO="https://github.com/ROCm/pytorch.git"
ARG PYTORCH_VISION_BRANCH="v0.24.1"
ARG PYTORCH_VISION_REPO="https://github.com/pytorch/vision.git"
ARG PYTORCH_AUDIO_BRANCH="v2.9.0"
ARG PYTORCH_AUDIO_REPO="https://github.com/pytorch/audio.git"
ARG TRITON_BRANCH="57c693b6"
ARG TRITON_REPO="https://github.com/ROCm/triton.git"
ARG FA_BRANCH="0e60e394"
ARG FA_REPO="https://github.com/Dao-AILab/flash-attention.git"

ARG PYTHON_VERSION=3.12


# ============================================================================
# Stage 1: Base — system packages, Python, env vars
# ============================================================================
FROM ${BASE_IMAGE} AS base

ARG PYTHON_VERSION
ENV PYTHON_VERSION=${PYTHON_VERSION}

# Target only Strix Halo GPUs
ENV PYTORCH_ROCM_ARCH="gfx1150;gfx1151"

# ROCm paths
ENV PATH=/opt/rocm/llvm/bin:/opt/rocm/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV ROCM_PATH=/opt/rocm
ENV LD_LIBRARY_PATH=/opt/rocm/lib:/usr/local/lib:

# Required for RCCL in ROCm 7.1+
ENV HSA_NO_SCRATCH_RECLAIM=1

# Required for AOTriton experimental kernels on gfx1151
ENV TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1

# Use gloo backend — NCCL is unstable on single-GPU APUs
ENV VLLM_DISTRIBUTED_BACKEND=gloo

# LLVM compiler regression workaround for ROCm 7.x
# See: https://github.com/llvm/llvm-project/pull/147700
ENV HIPCC_COMPILE_FLAGS_APPEND="-mllvm --amdgpu-unroll-threshold-local=600"

# Performance env vars
ENV HIP_FORCE_DEV_KERNARG=1
ENV SAFETENSORS_FAST_GPU=1
ENV TOKENIZERS_PARALLELISM=false

# MIOpen regression workaround
# See: https://github.com/pytorch/pytorch/issues/169857
ENV MIOPEN_DEBUG_CONV_DIRECT=0
ENV MIOPEN_DEBUG_CONV_GEMM=0

RUN mkdir -p /app
WORKDIR /app
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
# Ubuntu 24.04 ships Python 3.12 by default — no deadsnakes PPA needed.
# Remove PEP 668 marker so pip works globally (standard for Docker containers).
RUN apt-get update -y \
    && apt-get install -y \
        software-properties-common git curl sudo vim less wget \
        libgfortran5 libopenmpi-dev libpci-dev \
        sqlite3 libsqlite3-dev libfmt-dev libmsgpack-dev libsuitesparse-dev \
        libjpeg-dev libsox-dev libsox-fmt-all sox \
        apt-transport-https ca-certificates \
        python3 python3-dev python3-venv \
    && rm -f /usr/lib/python*/EXTERNALLY-MANAGED \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && python3 --version && python3 -m pip --version \
    && rm -rf /var/lib/apt/lists/*

# Install build tools
RUN pip install -U packaging 'cmake<4' ninja wheel 'setuptools<80' pybind11 Cython

# Install uv for fast dependency resolution
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/usr/local/bin" sh
ENV UV_HTTP_TIMEOUT=500
ENV UV_INDEX_STRATEGY="unsafe-best-match"
ENV UV_LINK_MODE=copy


# ============================================================================
# Stage 2: Build Triton from source
# ============================================================================
FROM base AS build_triton
ARG TRITON_BRANCH
ARG TRITON_REPO

RUN git clone ${TRITON_REPO}
RUN cd triton \
    && git checkout ${TRITON_BRANCH} \
    && if [ ! -f setup.py ]; then cd python; fi \
    && python3 setup.py bdist_wheel --dist-dir=dist \
    && mkdir -p /app/install && cp dist/*.whl /app/install
RUN if [ -d triton/python/triton_kernels ]; then \
        pip install build && cd triton/python/triton_kernels \
        && python3 -m build --wheel && cp dist/*.whl /app/install; \
    fi


# ============================================================================
# Stage 3: Build AMD SMI
# ============================================================================
FROM base AS build_amdsmi

# NOTE: amdsmi_init() can segfault on gfx1151 — vLLM handles this gracefully
# by falling back to torch.cuda for device detection (see vllm/platforms/rocm.py)
RUN cd /opt/rocm/share/amd_smi \
    && pip wheel . --wheel-dir=dist
RUN mkdir -p /app/install && cp /opt/rocm/share/amd_smi/dist/*.whl /app/install


# ============================================================================
# Stage 4: Build PyTorch, TorchVision, TorchAudio from source
# ============================================================================
FROM base AS build_pytorch
ARG PYTORCH_BRANCH
ARG PYTORCH_VISION_BRANCH
ARG PYTORCH_AUDIO_BRANCH
ARG PYTORCH_REPO
ARG PYTORCH_VISION_REPO
ARG PYTORCH_AUDIO_REPO

# Build PyTorch
RUN git clone ${PYTORCH_REPO} pytorch
RUN cd pytorch && git checkout ${PYTORCH_BRANCH} \
    && pip install -r requirements.txt && git submodule update --init --recursive \
    && python3 tools/amd_build/build_amd.py \
    && CMAKE_PREFIX_PATH=$(python3 -c 'import sys; print(sys.prefix)') \
       python3 setup.py bdist_wheel --dist-dir=dist \
    && pip install dist/*.whl

# Build TorchVision
RUN git clone ${PYTORCH_VISION_REPO} vision
RUN cd vision && git checkout ${PYTORCH_VISION_BRANCH} \
    && python3 setup.py bdist_wheel --dist-dir=dist \
    && pip install dist/*.whl

# Build TorchAudio
RUN git clone ${PYTORCH_AUDIO_REPO} audio
RUN cd audio && git checkout ${PYTORCH_AUDIO_BRANCH} \
    && git submodule update --init --recursive \
    && pip install -r requirements.txt \
    && python3 setup.py bdist_wheel --dist-dir=dist \
    && pip install dist/*.whl

RUN mkdir -p /app/install && cp /app/pytorch/dist/*.whl /app/install \
    && cp /app/vision/dist/*.whl /app/install \
    && cp /app/audio/dist/*.whl /app/install


# ============================================================================
# Stage 5: Build Flash Attention from source
# ============================================================================
FROM base AS build_fa
ARG FA_BRANCH
ARG FA_REPO

RUN --mount=type=bind,from=build_pytorch,src=/app/install/,target=/install \
    pip install /install/*.whl
RUN git clone ${FA_REPO}
# Strip gfx1xxx archs from FA build — CK Flash Attention does not support them.
# The Triton-based flash attention backend is used at runtime instead.
RUN cd flash-attention \
    && git checkout ${FA_BRANCH} \
    && git submodule update --init \
    && GPU_ARCHS=$(echo ${PYTORCH_ROCM_ARCH} | sed -e 's/;gfx1[0-9]\{3\}//g') \
       python3 setup.py bdist_wheel --dist-dir=dist
RUN mkdir -p /app/install && cp /app/flash-attention/dist/*.whl /app/install


# ============================================================================
# Stage 6: Collect all dependency wheels
# ============================================================================
FROM base AS debs
RUN mkdir /app/debs
RUN --mount=type=bind,from=build_triton,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs
RUN --mount=type=bind,from=build_fa,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs
RUN --mount=type=bind,from=build_amdsmi,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs
RUN --mount=type=bind,from=build_pytorch,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs

FROM base AS deps_installed
RUN --mount=type=bind,from=debs,src=/app/debs,target=/install \
    pip install /install/*.whl


# ============================================================================
# Stage 7: Build vLLM
# ============================================================================
FROM deps_installed AS build_vllm

COPY ./ /app/vllm/

RUN cd /app/vllm \
    && pip install -r requirements/rocm.txt \
    && python3 setup.py clean --all \
    && python3 setup.py bdist_wheel --dist-dir=dist


# ============================================================================
# Stage 8: Final runtime image
# ============================================================================
FROM deps_installed AS final

# Use --force-reinstall for pip to work around missing RECORD file from base image
RUN pip install --force-reinstall --upgrade pip && pip install huggingface-hub[cli]

# Install vLLM from the wheel we just built
RUN --mount=type=bind,from=build_vllm,src=/app/vllm/dist/,target=/tmp/vllm-dist \
    --mount=type=bind,from=build_vllm,src=/app/vllm/requirements/,target=/tmp/vllm-reqs \
    pip install -r /tmp/vllm-reqs/rocm.txt \
    && pip install /tmp/vllm-dist/*.whl

# Copy benchmarks and examples
COPY benchmarks /app/vllm/benchmarks
COPY examples /app/vllm/examples

# Enable fast downloads from HF
RUN pip install hf_transfer
ENV HF_HUB_ENABLE_HF_TRANSFER=1

# Workaround for ROCm profiler limits
RUN echo "ROCTRACER_MAX_EVENTS=10000000" > /app/libkineto.conf
ENV KINETO_CONFIG="/app/libkineto.conf"

# Record build metadata
ARG BASE_IMAGE
ARG PYTORCH_BRANCH
ARG TRITON_BRANCH
ARG FA_BRANCH
RUN echo "BASE_IMAGE: ${BASE_IMAGE}" > /app/versions.txt \
    && echo "PYTORCH_ROCM_ARCH: ${PYTORCH_ROCM_ARCH}" >> /app/versions.txt \
    && echo "PYTORCH_BRANCH: ${PYTORCH_BRANCH}" >> /app/versions.txt \
    && echo "TRITON_BRANCH: ${TRITON_BRANCH}" >> /app/versions.txt \
    && echo "FA_BRANCH: ${FA_BRANCH}" >> /app/versions.txt \
    && echo "Build type: Strix Halo (from source)" >> /app/versions.txt \
    && python3 -c "import torch; print(f'PyTorch: {torch.__version__}')" >> /app/versions.txt \
    && python3 -c "import triton; print(f'Triton: {triton.__version__}')" >> /app/versions.txt \
    && python3 -c "import vllm; print(f'vLLM: {vllm.__version__}')" >> /app/versions.txt || true

CMD ["/bin/bash"]


# ============================================================================
# OpenAI-compatible API server entrypoint
# ============================================================================
FROM final AS vllm-openai
ENTRYPOINT ["vllm", "serve"]
