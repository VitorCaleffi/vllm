# Dockerfile for AMD Strix Halo (gfx1151) APUs
#
# Based on kyuz0/amd-strix-halo-vllm-toolboxes — the community-proven approach
# for running vLLM on Strix Halo. Uses TheRock ROCm SDK and nightly PyTorch
# wheels (which include AOTriton for gfx1151) instead of building from source.
#
# Key differences from the upstream Dockerfile.rocm_base + Dockerfile.rocm:
#   - Single self-contained file (vs upstream's two-file base+app split)
#   - Uses TheRock ROCm SDK + nightly PyTorch wheels (not ROCm stable + from source)
#   - Targets only gfx1151 (Ryzen AI Max 395 / Radeon 8060S)
#   - Skips AITER, MORI, CK Flash Attention, amdsmi (unsupported on gfx11xx)
#   - All Strix Halo-specific env vars and workarounds pre-configured
#
# References:
#   - https://github.com/kyuz0/amd-strix-halo-vllm-toolboxes
#   - https://github.com/lhl/strix-halo-testing
#   - https://strixhalo.wiki/AI/vLLM
#
# Build:
#   docker build -f docker/Dockerfile.rocm.strix-halo -t vllm-strix-halo .
#
# Run:
#   docker run --device=/dev/kfd --device=/dev/dri \
#     --group-add video --group-add render \
#     --security-opt seccomp=unconfined \
#     vllm-strix-halo \
#     vllm serve <model> --dtype float16 --no-mmap
#
# Host requirements:
#   - Linux kernel >= 6.18.4 (older kernels have KFD bugs for Strix Halo)
#   - Avoid linux-firmware-20251125 (breaks ROCm); use 20260110 or later
#   - Kernel boot params: iommu=pt amdgpu.gttsize=126976 ttm.pages_limit=32505856
#   - BIOS GPU memory set to minimum (512MB); use GTT/TTM for unified memory
#   - Docker flags: --device=/dev/kfd --device=/dev/dri --group-add video
#                   --group-add render --security-opt seccomp=unconfined

ARG BASE_IMAGE=ubuntu:24.04
ARG GFX=gfx1151
ARG ROCM_MAJOR_VER=7

# TheRock nightly PyTorch wheel index for gfx1151
ARG PYTORCH_WHEEL_INDEX="https://rocm.nightlies.amd.com/v2-staging/gfx1151/"

# Flash Attention — ROCm fork, main_perf branch (per kyuz0)
ARG FA_BRANCH="main_perf"
ARG FA_REPO="https://github.com/ROCm/flash-attention.git"


# ============================================================================
# Stage 1: Base — system packages, TheRock ROCm SDK, Python venv
# ============================================================================
FROM ${BASE_IMAGE} AS base

ARG GFX
ARG ROCM_MAJOR_VER
ARG PYTORCH_WHEEL_INDEX

ENV DEBIAN_FRONTEND=noninteractive

# Target only Strix Halo GPU
ENV PYTORCH_ROCM_ARCH="gfx1151"
ENV HIP_ARCHITECTURES="gfx1151"
ENV AMDGPU_TARGETS="gfx1151"

# ROCm paths (set after tarball install)
ENV ROCM_PATH=/opt/rocm
ENV HIP_PLATFORM=amd
ENV HIP_PATH=/opt/rocm
ENV HIP_CLANG_PATH=/opt/rocm/llvm/bin
ENV PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:/opt/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64:/opt/rocm/llvm/lib

# Required for RCCL in ROCm 7.1+
ENV HSA_NO_SCRATCH_RECLAIM=1

# Required for AOTriton experimental kernels on gfx1151
ENV TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1
# Prefer default AOTriton kernels (recommended by lhl/strix-halo-testing)
ENV TORCH_ROCM_AOTRITON_PREFER_DEFAULT=1

# Use gloo backend — NCCL is unstable on single-GPU APUs
ENV VLLM_DISTRIBUTED_BACKEND=gloo

# LLVM compiler regression workaround for ROCm 7.x
# See: https://github.com/llvm/llvm-project/pull/147700
ENV HIPCC_COMPILE_FLAGS_APPEND="-mllvm --amdgpu-unroll-threshold-local=600"

# Performance env vars
ENV HIP_FORCE_DEV_KERNARG=1
ENV SAFETENSORS_FAST_GPU=1
ENV TOKENIZERS_PARALLELISM=false
ENV ROCBLAS_USE_HIPBLASLT=1
ENV RAY_EXPERIMENTAL_NOSET_ROCR_VISIBLE_DEVICES=1

# Flash Attention: use Triton AMD backend (not CK)
ENV FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE

# vLLM Strix Halo runtime flags
ENV VLLM_TARGET_DEVICE=rocm
ENV VLLM_USE_MMAP=0
ENV VLLM_ROCM_USE_AITER=0
ENV VLLM_ROCM_USE_AITER_MOE=0
ENV VLLM_USE_TRITON_AWQ=1

# MIOpen regression workaround
# See: https://github.com/pytorch/pytorch/issues/169857
ENV MIOPEN_DEBUG_CONV_DIRECT=0
ENV MIOPEN_DEBUG_CONV_GEMM=0

# ---- System packages ----
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3.12-venv \
        git curl wget ca-certificates \
        gcc g++ binutils make cmake ninja-build \
        aria2 tar xz-utils vim \
        libdrm-dev zlib1g-dev libssl-dev \
        libnuma-dev libatomic1 \
        libgoogle-perftools4t64 \
        libjpeg-dev libsox-dev libsox-fmt-all sox \
        libopenmpi-dev libpci-dev \
        libsqlite3-dev libfmt-dev libmsgpack-dev libsuitesparse-dev \
        libgfortran5 \
    && rm -rf /var/lib/apt/lists/*

# ---- Install TheRock ROCm SDK from nightly tarball ----
# This installs a self-contained ROCm to /opt/rocm (same approach as kyuz0)
RUN set -e \
    && cd /tmp \
    && BASE_URL="https://therock-nightly-tarball.s3.amazonaws.com" \
    && PREFIX="therock-dist-linux-${GFX}-${ROCM_MAJOR_VER}" \
    && KEY="$(curl -s "${BASE_URL}?list-type=2&prefix=${PREFIX}" \
         | tr '<' '\n' \
         | grep -o "therock-dist-linux-${GFX}-${ROCM_MAJOR_VER}\..*\.tar\.gz" \
         | sort -V | tail -n1)" \
    && echo "Downloading: ${KEY}" \
    && aria2c -x 16 -s 16 -j 16 --file-allocation=none "${BASE_URL}/${KEY}" -o therock.tar.gz \
    && mkdir -p /opt/rocm \
    && tar xzf therock.tar.gz -C /opt/rocm --strip-components=1 \
    && rm therock.tar.gz

# Detect HIP_DEVICE_LIB_PATH from installed SDK
RUN BITCODE_PATH=$(find /opt/rocm -type d -name bitcode -print -quit) \
    && echo "HIP_DEVICE_LIB_PATH=${BITCODE_PATH}" >> /etc/environment
ENV HIP_DEVICE_LIB_PATH=""
# Will be set dynamically; cmake finds it via ROCM_PATH

# ---- Python venv ----
RUN python3.12 -m venv /opt/venv
ENV VIRTUAL_ENV=/opt/venv
ENV PIP_NO_CACHE_DIR=1
RUN pip install --upgrade pip wheel packaging "setuptools<80" pybind11 Cython

# ---- Install PyTorch from TheRock nightly wheels ----
# These wheels already include AOTriton support for gfx1151.
RUN pip install --pre --index-url ${PYTORCH_WHEEL_INDEX} \
    torch torchaudio torchvision

# Verify PyTorch installation
RUN python -c "import torch; print(f'PyTorch {torch.__version__}, ROCm {torch.version.hip}')"

RUN mkdir -p /app
WORKDIR /app


# ============================================================================
# Stage 2: Build Flash Attention (ROCm fork, main_perf branch)
# ============================================================================
FROM base AS build_fa
ARG FA_BRANCH
ARG FA_REPO

RUN git clone ${FA_REPO} flash-attention \
    && cd flash-attention \
    && git checkout ${FA_BRANCH} \
    && python setup.py bdist_wheel --dist-dir=/app/fa-dist


# ============================================================================
# Stage 3: Build vLLM
# ============================================================================
FROM base AS build_vllm

# Install Flash Attention wheel
RUN --mount=type=bind,from=build_fa,src=/app/fa-dist/,target=/tmp/fa-dist \
    pip install /tmp/fa-dist/*.whl

# Copy vLLM source
COPY ./ /app/vllm/
WORKDIR /app/vllm

# ---- Apply Strix Halo patches ----
# Patch 1: Replace gfx1200;gfx1201 with gfx1151 in CMakeLists.txt
RUN sed -i 's/gfx1200;gfx1201/gfx1151/' CMakeLists.txt

# Patch 2: Disable amdsmi (segfaults on gfx1151) and hardcode gfx1151 detection
# Based on kyuz0/amd-strix-halo-vllm-toolboxes/scripts/patch_strix.py
RUN <<'PATCH_EOF'
python -c "
import re, glob
from pathlib import Path

# Patch vllm/platforms/__init__.py - disable amdsmi, force ROCm detection
p = Path('vllm/platforms/__init__.py')
if p.exists():
    t = p.read_text()
    t = t.replace('import amdsmi', '# import amdsmi')
    t = re.sub(r'is_rocm = .*', 'is_rocm = True', t)
    t = re.sub(r'if len\(amdsmi\.amdsmi_get_processor_handles\(\)\) > 0:', 'if True:', t)
    t = t.replace('amdsmi.amdsmi_init()', 'pass')
    t = t.replace('amdsmi.amdsmi_shut_down()', 'pass')
    p.write_text(t)
    print('Patched vllm/platforms/__init__.py')

# Patch vllm/platforms/rocm.py - mock amdsmi, hardcode gfx1151
p = Path('vllm/platforms/rocm.py')
if p.exists():
    t = p.read_text()
    header = 'import sys\nfrom unittest.mock import MagicMock\nsys.modules[\"amdsmi\"] = MagicMock()\n'
    t = header + t
    p.write_text(t)
    print('Patched vllm/platforms/rocm.py')

# Patch C/C++ sources - add missing macro definitions for PyTorch nightly compat
macro = '''
#ifndef C10_HIP_CHECK
#define C10_HIP_CHECK(error) do { if (error != hipSuccess) { abort(); } } while(0)
#endif
#ifndef C10_CUDA_CHECK
#define C10_CUDA_CHECK(error) do { if (error != cudaSuccess) { abort(); } } while(0)
#endif
'''
count = 0
for f in glob.glob('csrc/**/*.cu', recursive=True) + glob.glob('csrc/**/*.hip', recursive=True):
    p = Path(f)
    t = p.read_text()
    if 'C10_CUDA_CHECK' not in t:
        p.write_text(macro + '\n' + t)
        count += 1
print(f'Patched {count} C/C++ source files with missing macros')
"
PATCH_EOF

# ---- Build vLLM ----
# Use ROCm Clang as the host compiler to align ABI with PyTorch (per kyuz0)
ENV CC=/opt/rocm/llvm/bin/clang
ENV CXX=/opt/rocm/llvm/bin/clang++
ENV ROCM_HOME=/opt/rocm
ENV MAX_JOBS=4

RUN pip install --upgrade cmake ninja packaging wheel "setuptools-scm>=8" "setuptools<80" \
    scikit-build-core pybind11

RUN export HIP_DEVICE_LIB_PATH=$(find /opt/rocm -type d -name bitcode -print -quit) \
    && echo "Building with HIP_DEVICE_LIB_PATH=$HIP_DEVICE_LIB_PATH" \
    && pip wheel --no-build-isolation --no-deps -w /app/vllm-dist -v .


# ============================================================================
# Stage 4: Final runtime image
# ============================================================================
FROM base AS final

# Install Flash Attention
RUN --mount=type=bind,from=build_fa,src=/app/fa-dist/,target=/tmp/fa-dist \
    pip install /tmp/fa-dist/*.whl

# Install vLLM
RUN --mount=type=bind,from=build_vllm,src=/app/vllm-dist/,target=/tmp/vllm-dist \
    pip install /tmp/vllm-dist/*.whl

# Install additional runtime dependencies
RUN pip install huggingface-hub[cli] hf_transfer ray
ENV HF_HUB_ENABLE_HF_TRANSFER=1

# Copy benchmarks and examples
COPY benchmarks /app/vllm/benchmarks
COPY examples /app/vllm/examples

# Workaround for ROCm profiler limits
RUN echo "ROCTRACER_MAX_EVENTS=10000000" > /app/libkineto.conf
ENV KINETO_CONFIG="/app/libkineto.conf"

# Record build metadata
ARG GFX
ARG ROCM_MAJOR_VER
RUN echo "Build type: Strix Halo (TheRock ROCm SDK)" > /app/versions.txt \
    && echo "Target GPU: ${GFX}" >> /app/versions.txt \
    && echo "ROCm major version: ${ROCM_MAJOR_VER}" >> /app/versions.txt \
    && python -c "import torch; print(f'PyTorch: {torch.__version__}')" >> /app/versions.txt \
    && python -c "import triton; print(f'Triton: {triton.__version__}')" >> /app/versions.txt \
    && python -c "import vllm; print(f'vLLM: {vllm.__version__}')" >> /app/versions.txt || true

CMD ["/bin/bash"]


# ============================================================================
# OpenAI-compatible API server entrypoint
# ============================================================================
FROM final AS vllm-openai
ENTRYPOINT ["vllm", "serve"]
